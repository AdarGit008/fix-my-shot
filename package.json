{
  "name": "fix-my-shot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Off-court basketball shot-form trainer — grade an editable, physically-real shooting pose against research-derived principles.",
  "license": "MIT",
  "author": "Adar",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @fix-my-shot/web",
    "build": "npm run build --workspace @fix-my-shot/web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "spike:measure": "npm run build --workspace @fix-my-shot/web && node tools/spike-measure.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "bin/setup"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "globals": "^17.7.0",
    "prettier": "^3.4.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
